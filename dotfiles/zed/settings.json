  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-5-latest",
    },
    "model_parameters": [],
  },
  "languages": {
    "Python": {
      "language_servers": [
        // Disable basedpyright and enable ty, and otherwise
        // use the default configuration.
        "ty",
        "!basedpyright",
        "!pylsp",
        "...",
      ],
    },
    "SQL": {
      "tab_size": 2,
    },
    "Clojure": {
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "Markdown": {
      // "formatter": {
      //   "external": {
      //     "command": "prettier",
      //     "arguments": [
      //       "--prose-wrap",
      //       "always",
      //       "--stdin-filepath",
      //       "{buffer_path}",
      //     ],
      //   },
      // },
      "format_on_save": "on",
    },
    "Java": {
      "format_on_save": "off",
    },
    // "TypeScript": {
    //   "language_servers": ["tsgo"]
    // }
  },
  "use_system_window_tabs": true,
  "pane_split_direction_vertical": "right",
  "base_keymap": "VSCode",
  "theme": "One Dark",
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 15,
  // vim related
  "relative_line_numbers": "enabled",
  // hide the scroll bar
  "scrollbar": { "show": "never" },
  // don't allow cursor to reach edges of screen
  "vertical_scroll_margin": 20,
  "tab_bar": {
    "show": false,
  },
  "format_on_save": "on",
  "lsp": {
    "jdtls": {
      "settings": {
        "lombok_support": true,
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        // "diagnostics": {
        //   "experimental": {
        //     "enable": true
        //   }
        // },
        "checkOnSave": true,
        "cargo": {
          "allTargets": false,
          // "buildScripts": {
          //   // "rebuildOnSave": false,
          //   "useRustcWrapper": false
          // },
          // "extraEnv": {
          //   "RUSTC_WRAPPER": "/opt/homebrew/bin/sccache"
          // }
        },
        // "check": {
        //   "overrideCommand": [
        //     "cargo check --quiet --workspace --message-format=json"
        //   ]
        // }
      },
    },
  },
}
